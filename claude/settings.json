{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "cleanupPeriodDays": 30,
  "includeCoAuthoredBy": true,
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"${TMUX_AGENT_INDICATOR_DIR:-/home/ichesal/.config/tmux/plugins/tmux-agent-indicator}\"/scripts/agent-state.sh --agent claude --state running"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"${TMUX_AGENT_INDICATOR_DIR:-/home/ichesal/.config/tmux/plugins/tmux-agent-indicator}\"/scripts/agent-state.sh --agent claude --state needs-input"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"${TMUX_AGENT_INDICATOR_DIR:-/home/ichesal/.config/tmux/plugins/tmux-agent-indicator}\"/scripts/agent-state.sh --agent claude --state done"
          }
        ]
      }
    ]
