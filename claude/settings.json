    "mcp__claude_ai_Atlassian__getAccessibleAtlassianResources",
    "mcp__claude_ai_Notion__notion-query-meeting-notes",
    "Read"
  ],
  "alwaysThinkingEnabled": true,
  "fastMode": true,
  "autoUpdatesChannel": "latest",
