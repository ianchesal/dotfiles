#!/usr/bin/env ruby
# frozen_string_literal: true

# Generates zsh/completions/_claude from `claude --help` output.
# Run directly or via: rake claude:gen_completions

help_text = `claude --help 2>&1`
version   = `claude --version 2>/dev/null`.strip

options  = []
commands = []

current_section = nil
help_text.each_line do |raw|
  line = raw.chomp

  case line.strip
  when 'Options:'   then current_section = :options;  next
  when 'Commands:'  then current_section = :commands; next
  when 'Arguments:' then current_section = :arguments; next
  end

  next if line.strip.empty?

  if current_section == :options && line =~ /^\s{2}(-\S.*?)\s{2,}(.+)$/
    flags_and_arg = ::Regexp.last_match(1).strip
    description   = ::Regexp.last_match(2).strip

    arg_spec  = ''
    flags_str = flags_and_arg
    if flags_and_arg =~ /^(.*?)\s+(\[.+?\]|<.+?>)\s*$/
      flags_str = ::Regexp.last_match(1)
      arg_spec  = ::Regexp.last_match(2)
    end

    flags = flags_str.split(/,\s*/).map(&:strip).reject(&:empty?)

    choices = []
    if description =~ /\(choices:\s+(.+?)\)\s*$/
      raw_choices = ::Regexp.last_match(1)
      choices = raw_choices.scan(/"([^"]+)"/).flatten
      choices = raw_choices.split(/,\s*/).map(&:strip) if choices.empty?
    end

    options << { flags: flags, arg: arg_spec, description: description, choices: choices }
  end

  if current_section == :commands && line =~ /^\s{2}(\S+)\s{2,}(.+)$/
    name = ::Regexp.last_match(1).split('|').first
    desc = ::Regexp.last_match(2).strip
    commands << { name: name, description: desc }
  end
end

def short_desc(str)
  # Truncate to first sentence to keep descriptions brief and avoid quoting issues
  str.split(/(?<=\.)\s+/).first.to_s
     .gsub('[', '\\[').gsub(']', '\\]')   # escape zsh bracket metacharacters
     .gsub("'", %q('\\\''))               # escape single quotes: ' -> '\''
     .strip
end

def short_subcmd_desc(str)
  str.split(/(?<=\.)\s+/).first.to_s
     .gsub("'", %q('\\\''))
     .gsub(':', '\\:')
     .strip
end

spec_lines = []

options.each do |opt|
  flags   = opt[:flags]
  arg     = opt[:arg]
  desc    = short_desc(opt[:description])
  choices = opt[:choices]

  arg_name = arg.tr('<>[]', '').strip.split('.').first.to_s.tr(' ', '-')
  optional = arg.start_with?('[')

  arg_completion = if !choices.empty?
    ":#{arg_name}:(#{choices.join(' ')})"
  elsif !arg.empty?
    ":#{arg_name}:"
  else
    ''
  end
  arg_completion = ":#{arg_completion}" if optional && !arg_completion.empty?

  if flags.length >= 2 && flags.all? { |f| f.start_with?('--') }
    # Two long aliases (e.g. --allowedTools and --allowed-tools)
    flags.each { |flag| spec_lines << "    '#{flag}[#{desc}]#{arg_completion}' \\" }
  elsif flags.length == 2 && flags.any? { |f| f =~ /^-[^-]/ }
    short = flags.find { |f| f =~ /^-[^-]/ }
    long  = flags.find { |f| f.start_with?('--') }
    spec_lines << "    '(#{short} #{long})'{#{short},#{long}}'[#{desc}]#{arg_completion}' \\"
  else
    flags.each { |flag| spec_lines << "    '#{flag}[#{desc}]#{arg_completion}' \\" }
  end
end

subcmd_lines = commands.map do |c|
  "      '#{c[:name]}:#{short_subcmd_desc(c[:description])}'"
end.join("\n")

output = <<~ZSH
  #compdef claude
  # Generated by script/gen-claude-completions from claude #{version}
  # Do not edit by hand — regenerate with: rake claude:gen_completions

  _claude() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \\
  #{spec_lines.join("\n")}
      '1:prompt:' \\
      '*::args:->subcmd' && return 0

    case $state in
      subcmd)
        local -a subcommands
        subcommands=(
  #{subcmd_lines}
        )
        _describe 'subcommand' subcommands
        ;;
    esac
  }

  _claude "$@"
ZSH

dest = File.expand_path('../../zsh/completions/_claude', __FILE__)
File.write(dest, output)
puts "Wrote #{dest} (#{version})"
